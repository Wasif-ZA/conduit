# ============================================
# Conduit — environment variables
# ============================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored. Never commit real secrets.
# Rotate any secret that lands in git history.

# --------------------------------------------
# App
# --------------------------------------------
NEXT_PUBLIC_APP_URL=https://tryconduit.dev
NEXT_PUBLIC_APP_NAME=Conduit

# --------------------------------------------
# Supabase (auth + Postgres + RLS)
# --------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --------------------------------------------
# Notion OAuth (public integration)
# Created at https://www.notion.so/profile/integrations
# --------------------------------------------
NOTION_OAUTH_CLIENT_ID=
NOTION_OAUTH_CLIENT_SECRET=
NOTION_AUTHORIZATION_URL=https://api.notion.com/v1/oauth/authorize

# --------------------------------------------
# Nango (Cloud for Week 1 spike)
# Sign up at https://app.nango.dev
# --------------------------------------------
NANGO_SECRET_KEY=
NEXT_PUBLIC_NANGO_PUBLIC_KEY=
NANGO_HOST=https://api.nango.dev

# --------------------------------------------
# MCP runtime
# --------------------------------------------
# Generated per-endpoint, hashed with argon2 before storage.
# No global key needed; tokens live in `endpoints.token_hash`.
